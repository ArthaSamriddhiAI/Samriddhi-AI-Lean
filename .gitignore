# Operating system
.DS_Store
Thumbs.db

# Editor / IDE / agent state
.vscode/
.idea/
*.swp
*.swo

# Claude Code state. Ignore local-only files (launch.json, settings.local.json),
# but track committed, versioned team config so conventions live in the repo.
# Subagents are un-ignored now; skills, commands, and settings.json are
# un-ignored at their build waves. (Anchored-glob pattern so git can descend,
# matching the fixtures block below.)
.claude/*
!.claude/agents/
!.claude/settings.json

# Node / Next.js (added when scaffolding starts)
node_modules/
.next/
out/
dist/

# Environment / secrets
.env
.env.local
.env.*.local

# Database (Prisma SQLite, added during scaffolding)
*.db
*.db-journal
prisma/dev.db
prisma/migrations/dev_*/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Test coverage
coverage/

# Build artifacts
build/
*.tsbuildinfo

# Temporary files
*.tmp
.cache/

# Full-fat repo clone (kept out of working tree if accidentally cloned in)
artha-fullfat/

# Snapshot fixtures (copied locally by scripts/copy-fixtures.ts; ~99 MB total).
# Anchored at root so db/fixtures/ (seed-time TypeScript data) is NOT ignored.
# Stub-mode response fixtures under /fixtures/stub-responses/ are tracked
# (small JSONs, demo-critical for STUB_MODE replay).
/fixtures/*
!/fixtures/stub-responses/
# Enriched snapshots are NO LONGER committed. As of Phase B (ADR-0027) they are
# proprietary data fetched from the private Samriddhi-AI-Data-Snapshots repo by
# `npm run setup-data` and land at fixtures/snapshots/enriched/ (gitignored via
# the "Proprietary data" block at the end of this file; the pre-enrichment
# source payload was always gitignored too). We still re-include the snapshots/
# dir so git can descend, but the explicit block below untracks the JSON files.
!/fixtures/snapshots/
/fixtures/snapshots/*
!/fixtures/snapshots/enriched/

# Python bytecode (created when importing scripts/*.py)
__pycache__/
*.pyc

# Real-world-sourced proprietary data fetched from the private
# Samriddhi-AI-Data-Snapshots repo (ADR-0027). Fetched by `npm run setup-data`,
# pinned via data-version.txt; never tracked in this repo. The original
# committed copies are removed from the index here and purged from history in
# Phase C. Privacy boundary: only real-world-sourced data (vendor/exchange
# feeds) is private. The fictional investor holdings/mandates
# (db/fixtures/structured-*.ts) and the hand-authored Sharma evidence verdicts
# (db/fixtures/raw/) are invented creative content and stay tracked in this repo.
fixtures/snapshots/enriched/snapshot_*.json
scripts/sector_map.json
