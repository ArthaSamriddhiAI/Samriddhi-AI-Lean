# Operating system
.DS_Store
Thumbs.db

# Editor / IDE / agent state
.vscode/
.idea/
.claude/
*.swp
*.swo

# Node / Next.js (added when scaffolding starts)
node_modules/
.next/
out/
dist/

# Environment / secrets
.env
.env.local
.env.*.local

# Database (Prisma SQLite, added during scaffolding)
*.db
*.db-journal
prisma/dev.db
prisma/migrations/dev_*/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Test coverage
coverage/

# Build artifacts
build/
*.tsbuildinfo

# Temporary files
*.tmp
.cache/

# Full-fat repo clone (kept out of working tree if accidentally cloned in)
artha-fullfat/

# Snapshot fixtures (copied locally by scripts/copy-fixtures.ts; ~99 MB total).
# Anchored at root so db/fixtures/ (seed-time TypeScript data) is NOT ignored.
# Stub-mode response fixtures under /fixtures/stub-responses/ are tracked
# (small JSONs, demo-critical for STUB_MODE replay).
/fixtures/*
!/fixtures/stub-responses/
# Enriched snapshots are committed demo seed (not build artifacts). /fixtures/*
# blocks git from descending into fixtures/snapshots/, so re-include that dir,
# re-ignore its source payload (~99 MB, still copied locally), then track only
# fixtures/snapshots/enriched/.
!/fixtures/snapshots/
/fixtures/snapshots/*
!/fixtures/snapshots/enriched/
