  "private": true,
  "description": "Lean Samriddhi MVP: a demo-grade portfolio diagnostic and proposal evaluation tool for Indian HNI wealth advisors.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
