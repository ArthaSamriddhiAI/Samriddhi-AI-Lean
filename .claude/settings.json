{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git check-ignore *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm run build *)",
      "Bash(npm run typecheck *)",
      "Bash(tsc *)",
      "Bash(npm run check:persona-snapshot *)",
      "Agent(grounding-audit)",
      "Agent(Explore)"
    ],
    "deny": [
      "AskUserQuestion",
      "Write(//**/.claude/projects/**/memory/**)",
      "Edit(//**/.claude/projects/**/memory/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ],
    "ask": [
      "Bash(gh pr merge *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/gate-sensitive-bash.sh\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/wa07-no-long-dashes.sh\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/wa13-naming-reminder.sh\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/wa14-data-privacy-flag.sh\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/persona-snapshot-reminder.sh\"" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/guard-memory-writes.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/hooks/auto-push.sh\"" }
        ]
      }
    ]
  }
}
