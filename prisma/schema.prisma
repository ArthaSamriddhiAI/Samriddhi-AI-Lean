// Lean Samriddhi MVP database schema.
// SQLite for local single-user demo. Three core tables (investors, snapshots,
// cases) plus a single-row settings table for advisor configuration. Snapshot
// JSONs live on disk under fixtures/snapshots; only metadata is stored here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Investor {
  id                    String   @id
  name                  String
  displayInitials       String
  metaLine              String
  structureLine         String
  riskAppetite          String
  timeHorizon           String
  modelCell             String
  liquidAumCr           Float
  liquidityTier         String
  location              String
  profileMd             String
  // Structured portfolio holdings derived from foundation §4 tables.
  // JSON-encoded StructuredHoldings shape (db/fixtures/structured-holdings.ts).
  // Drives deterministic metrics and snapshot look-through; the profileMd
  // remains the human-readable view.
  holdingsJson          String
  // Structured mandate (asset-class bands, wrapper-count ceilings, position
  // concentration limits, sector / instrument exclusions). JSON-encoded
  // Mandate shape (db/fixtures/structured-mandates.ts). Read by Slice 3's
  // G1 deterministic governance gate. Slice 2 ignored mandates; Slice 3
  // adds this column with the schema lift confirmed in the orientation Q1
  // scoping response. Nullable to allow additive db:push (seed populates
  // every investor); G1 treats a null mandate as requires_clarification
  // at runtime.
  mandateJson           String?
  onboardingTranscript  String?
  createdAt             DateTime @default(now())

  cases                 Case[]

  @@map("investors")
}

model Snapshot {
  id              String   @id
  date            DateTime
  type            String
  testAxis        String
  filePath        String
  holdingsCount   Int      @default(0)

  cases           Case[]

  @@map("snapshots")
}

model Case {
  id              String   @id
  investorId      String
  snapshotId      String
  workflow        String
  severity        String
  headline        String
  // status: "generating" | "ready" | "failed" | "archived"
  status          String?
  frozenAt        DateTime @default(now())
  contentJson     String
  // Per-agent token usage rollup, JSON-encoded. Populated when status="ready".
  tokenUsageJson  String?
  // Populated when status="failed" with the human-readable cause.
  errorMessage    String?
  contextNote     String?
  // True when this case was assembled from STUB_MODE replay (pre-recorded
  // agent responses), false when assembled from live SDK calls. Null on
  // legacy cases generated before Slice 3 commit 8 added the column; the
  // UI treats null as false (live). Drives the Case Detail "Stubbed
  // reasoning" badge, the Case List signal, and the PDF footer line.
  stubbed         Boolean?

  investor        Investor @relation(fields: [investorId], references: [id])
  snapshot        Snapshot @relation(fields: [snapshotId], references: [id])

  @@index([investorId])
  @@index([snapshotId])
  @@map("cases")
}

model Setting {
  id                    Int      @id @default(1)
  apiKey                String?
  modelChoice           String   @default("claude-opus-4-7")
  advisorName           String   @default("Priya Nair")
  firmName              String   @default("Anand Rathi Wealth · UHNI desk")
  // Per-case token-budget circuit breaker. Combined input + output across
  // all agents in one diagnostic run. Sized as a guardrail against runaway
  // loops, not a budget target: routine cases come in well below this.
  tokenBudgetPerCase    Int      @default(250000)
  // Stub mode override. null = inherit env STUB_MODE; true/false = explicit
  // override set via Settings UI. When stub mode is active, stub-aware agent
  // call sites load pre-recorded responses from fixtures/stub-responses/
  // instead of calling the Anthropic SDK. Slice 3 commit 1 infrastructure;
  // Settings UI toggle lands in commit 8.
  stubMode              Boolean?
  updatedAt             DateTime @updatedAt

  @@map("settings")
}
