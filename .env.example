DATABASE_URL="file:./dev.db"

# Stub mode. When true, stub-aware agent call sites dispatch to recorded
# fixtures under fixtures/stub-responses/<case-fixture-id>/<agent-id>.json
# instead of calling the Anthropic SDK. Production default false; local
# development convention is true. The Settings UI override (Setting.stubMode)
# takes precedence over this env var when set to a non-null value.
STUB_MODE=false

# Stub recording. When true, successful real-mode SDK responses are written
# to the fixture path above if no fixture exists yet. Enables incidental
# fixture capture during live runs. Production default false; local
# development convention is true. No Settings UI override; env is the only
# knob. The recorded fixture stores the raw SDK response text and usage;
# stub-loader replays through the same parser the live call site uses.
STUB_RECORD=false
